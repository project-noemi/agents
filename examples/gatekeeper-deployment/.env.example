# Gatekeeper + Fleet Dashboard — Required Environment Variables
# All values should be injected via vault CLI wrappers at runtime.
# Usage: op run --env-file=.env.template -- docker compose up -d

# GitHub token with repo, read:org, write:discussion scopes
GH_TOKEN=op://Vault/Gatekeeper/token

# GitHub organization to scan
GATEKEEPER_ORG=your-org-name

# Optional: comma-separated repo allowlist (empty = scan all)
GATEKEEPER_REPOS=

# Dry-run mode: set to "false" to enable actual merges/closes
GATEKEEPER_DRY_RUN=true

# Triage interval in hours
GATEKEEPER_INTERVAL_HOURS=4

# HMAC signing secret for dashboard report authentication
GATEKEEPER_HMAC_SECRET=op://Vault/Gatekeeper HMAC Secret/credential

# Slack incoming webhook URL for notifications
SLACK_WEBHOOK_URL=op://Vault/Slack Webhook/url

# InfluxDB credentials
INFLUXDB_PASSWORD=op://Vault/InfluxDB/password
INFLUXDB_ADMIN_TOKEN=op://Vault/InfluxDB/admin-token

# Grafana admin password
GF_ADMIN_PASSWORD=op://Vault/Grafana/admin-password
