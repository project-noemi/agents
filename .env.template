# Project NoéMI - Agent Orchestration Environment Variables
# Used by external orchestrators (like Gemini CLI, n8n) executing these agents.
#
# SECURITY: All values are resolved at runtime via vault CLI wrappers.
# Usage:  op run --env-file=.env.template -- <command>
#    or:  infisical run --env=dev -- <command>
# Never hardcode actual secret values. Placeholder values below are vault
# reference syntax — replace with your vault's reference format.

# Which MCPs should be active by default?
# In standalone/CLI execution, can be overridden by orchestrator configs or mcp.config.json.
ACTIVE_MCPS=n8n,slack,gmail,google-drive,google-calendar,google-docs,google-sheets,google-slides,google-meet,google-chat,google-keep,google-forms,google-contacts,google-admin,web-search,github

# API Keys referenced by MCPs (resolved from vault at runtime)
GITHUB_PERSONAL_ACCESS_TOKEN=op://noemi/github/token
SLACK_BOT_TOKEN=op://noemi/slack/bot-token
GEMINI_API_KEY=op://noemi/google/gemini-api-key
OPENAI_API_KEY=op://noemi/openai/api-key
ANTHROPIC_API_KEY=op://noemi/anthropic/api-key

# Fleet Deployment — Identity Layer (Casdoor)
CASDOOR_DB_PASSWORD=op://noemi/casdoor-db/password

# Fleet Deployment — Observability Stack (Grafana)
GF_ADMIN_PASSWORD=op://noemi/grafana/admin-password

# Fleet Deployment — Cohort Databases
COHORT01_DB_PASSWORD=op://noemi/cohort01-db/password
COHORT02_DB_PASSWORD=op://noemi/cohort02-db/password

# Local Server Configurations (if applicable)
MCP_PORT=8080
LOG_LEVEL=info
